{
  "name": "jotai-gpu",
  "version": "0.0.0",
  "private": true,
  "description": "Declarative Jōtai-based API for TypeGPU",
  "keywords": [
    "declarative",
    "graphics",
    "jotai",
    "react",
    "typegpu",
    "webgpu"
  ],
  "license": "MIT",
  "author": "Iwo Plaza",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "directory": "dist",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "module": "./dist/index.js",
        "import": "./dist/index.js",
        "default": "./dist/index.cjs"
      }
    },
    "linkDirectory": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "test:types": "pnpm tsc --p ./tsconfig.json --noEmit",
    "publish": "echo \"Use pnpm prepare-package instead!\" && exit 1",
    "prepare-package": "node ./tools/prepack.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.9.3",
    "@webgpu/types": "catalog:",
    "jotai": "^2.10.0",
    "remeda": "^2.17.3",
    "tsup": "^8.3.5",
    "typegpu": "catalog:",
    "vitest": "^2.1.5"
  },
  "peerDependencies": {
    "jotai": ">=2.0.0",
    "typegpu": ">=0.5.8"
  },
  "packageManager": "pnpm@10.11.1+sha512.e519b9f7639869dc8d5c3c5dfef73b3f091094b0a006d7317353c72b124e80e1afd429732e28705ad6bfa1ee879c1fce46c128ccebd3192101f43dd67c667912"
}
