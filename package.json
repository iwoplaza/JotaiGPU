{
  "name": "jotai-gpu-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Iwo Plaza",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:test": "vitest",
    "fix": "oxfmt && oxlint --fix",
    "check": "oxfmt --check && oxlint",
    "test": "pnpm run '/^test:.*/'",
    "test:types": "pnpm run -r test:types",
    "test:spec": "vitest run",
    "automd": "npx automd@latest --input=\"**/*.md\""
  },
  "devDependencies": {
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.5.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@10.11.1+sha512.e519b9f7639869dc8d5c3c5dfef73b3f091094b0a006d7317353c72b124e80e1afd429732e28705ad6bfa1ee879c1fce46c128ccebd3192101f43dd67c667912",
  "pnpm": {
    "overrides": {
      "jotai": "catalog:"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
